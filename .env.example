# ─────────────────────────────────────────────────────────────────────────────
# InSync Profiles — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on (Railway/Render set this automatically)
PORT=3000

# Node environment: development | production
NODE_ENV=production

# ── Database (MySQL) ──────────────────────────────────────────────────────────
# Free MySQL options:
#   - PlanetScale (free tier): https://planetscale.com
#   - Railway MySQL plugin: https://railway.app
#   - Aiven (free tier): https://aiven.io
#   - Clever Cloud (free tier): https://www.clever-cloud.com
#
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://user:password@host:3306/insync_profiles

# ── App ───────────────────────────────────────────────────────────────────────
# Your public domain (no trailing slash)
# Used in QR codes and profile share URLs
VITE_APP_DOMAIN=https://yourdomain.com

# ── Licence Activation Notifications (optional) ───────────────────────────────
# Set this to receive a notification when a buyer activates their licence key.
# Supports any POST webhook: Make.com, Zapier, n8n, Discord, Slack, etc.
#
# Discord example: https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN
# Slack example:   https://hooks.slack.com/services/T.../B.../...
# Make.com:        https://hook.eu1.make.com/...
#
# Leave blank to disable notifications.
VITE_NOTIFICATION_WEBHOOK_URL=
